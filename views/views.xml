<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_action_endpoint_manager_list" model="ir.ui.view">
        <field name="name">action.endpoint.manager.list</field>
        <field name="model">action.endpoint.manager</field>
        <field name="arch" type="xml">
            <list string="Endpoint Managers">
                <field name="name"/>
                <field name="model_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_action_endpoint_manager_form" model="ir.ui.view">
        <field name="name">action.endpoint.manager.form</field>
        <field name="model">action.endpoint.manager</field>
        <field name="arch" type="xml">
            <form string="Endpoint Manager">
                <header>
                    <button name="action_generate_endpoints" 
                            type="object" 
                            string="Generate actions" 
                            class="oe_highlight" 
                            icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="E.g: Endpoints for contract"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Endpoints List">
                            <field name="generated_action_ids">
                                <list>
                                    <field name="name" string="Action name"/>
                                    <field name="code" string="Code"/>
                                    <field name="write_date" string="Last updated"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_endpoint_manager_window" model="ir.actions.act_window">
        <field name="name">Action Endpoints Management</field>
        <field name="res_model">action.endpoint.manager</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem 
      id="menu_action_endpoint_root" 
      name="Action Endpoints" 
      sequence="15"
    />
    <menuitem 
      id="menu_action_endpoint_manager" 
      name="Endpoints" 
      parent="menu_action_endpoint_root" 
      action="action_endpoint_manager_window" 
      sequence="10"
    />
</odoo>